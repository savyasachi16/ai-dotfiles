# Deployed settings — only the .tpl is tracked
settings.json

# Runtime and ephemeral state
history.jsonl
backups/
cache/
todos/
projects/
shell-snapshots/
statsig/
session-env/
sessions/
telemetry/
plans/

# Machine-specific config
policy-limits.json

# Plugin state (marketplace downloads, personal blocklist)
plugins/

# IDE integration state
ide/

# Backup dirs created by setup.sh
.dotfiles-backup-*/

# Third-party skills installed via `npx skills add` (Claude Code's
# ~/.claude/skills is symlinked to extensions/skills/, so installs land here)
extensions/skills/*
!extensions/skills/.gitkeep

# macOS
.DS_Store
